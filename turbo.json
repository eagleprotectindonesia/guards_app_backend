{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "web#build": {
      "dependsOn": [
        "@repo/database#prisma:generate",
        "@repo/shared#type-check",
        "@repo/types#type-check",
        "@repo/validations#type-check"
      ],
      "env": ["DATABASE_URL", "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "worker#build": {
      "dependsOn": [
        "@repo/database#prisma:generate",
        "@repo/shared#type-check",
        "@repo/types#type-check",
        "@repo/validations#type-check"
      ],
      "env": ["DATABASE_URL"],
      "outputs": ["dist/**"]
    },
    "@repo/database#lint": {
      "dependsOn": ["@repo/database#type-check"]
    },
    "@repo/shared#lint": {
      "dependsOn": ["@repo/shared#type-check"]
    },
    "mobile#lint": {
      "dependsOn": ["mobile#type-check"]
    },
    "web#lint": {
      "dependsOn": ["web#type-check"]
    },
    "worker#lint": {
      "dependsOn": ["worker#type-check"]
    },
    "@repo/database#type-check": {
      "dependsOn": ["@repo/database#prisma:generate"]
    },
    "@repo/shared#type-check": {},
    "@repo/types#type-check": {},
    "@repo/validations#type-check": {},
    "mobile#type-check": {
      "dependsOn": ["@repo/shared#type-check", "@repo/types#type-check", "@repo/validations#type-check"]
    },
    "web#type-check": {
      "dependsOn": [
        "@repo/database#prisma:generate",
        "@repo/shared#type-check",
        "@repo/types#type-check",
        "@repo/validations#type-check"
      ]
    },
    "worker#type-check": {
      "dependsOn": [
        "@repo/database#prisma:generate",
        "@repo/shared#type-check",
        "@repo/types#type-check",
        "@repo/validations#type-check"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:https": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["web#build", "worker#build"],
      "outputs": ["coverage/**"]
    },
    "@repo/database#prisma:generate": {
      "env": ["DATABASE_URL"],
      "cache": false
    },
    "@repo/database#db:push": {
      "dependsOn": ["@repo/database#prisma:generate"],
      "env": ["DATABASE_URL"],
      "cache": false
    }
  }
}
