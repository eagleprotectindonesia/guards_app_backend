# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ep_guard?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="ep_guard"

# Redis
REDIS_URL="redis://localhost:6379"

# Socket.io (CORS)
# Comma-separated list of allowed origins (e.g., http://localhost:3000,https://admin.example.com)
ALLOWED_ORIGINS="*"

# Authentication
JWT_SECRET="your_secure_jwt_secret_here"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# TinyMCE
NEXT_PUBLIC_TINYMCE_API_KEY=""

# Business Logic
REQUIRE_MOBILE_GUARD_LOGIN="false"

# AWS S3 (File Uploads)
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""

AWS_SES_FROM_EMAIL=""
AWS_SES_FROM_NAME=""
AWS_SES_REGION=""
AWS_SES_REPLY_TO_EMAIL=""
# Optional SES Configuration Set. Leave empty to avoid link/open tracking rewrites.
# If set, ensure your SES configuration set does not include CLICK/OPEN event destinations
# when you want clean original links in email bodies.
AWS_SES_CONFIGURATION_SET=""

EXTERNAL_EMPLOYEE_ADDRESS=
EXTERNAL_EMPLOYEE_API_KEY=

# Internal API / Revalidation
INTERNAL_REVALIDATE_SECRET="your_shared_revalidate_secret_here"
# Use http://localhost:3000 for local dev
# Use your public domain for production, e.g. https://admin.yourdomain.com
WEB_APP_URL="http://localhost:3000"

# Do NOT use localhost in production email links.
EMAIL_WEB_APP_URL=

# Firebase (Backend - server only)
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Firebase (Web/PWA - public client config)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Sentry (Web)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
# Optional explicit environment name override (e.g. production, staging, development)
SENTRY_ENVIRONMENT=""

ENABLE_ADMIN_LEAVE_OWNERSHIP=true
ENABLE_OFFICE_WORK_SCHEDULES=false
