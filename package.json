{
  "name": "ep-guard-scheduling",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "build": "turbo build",
    "dev": "node --env-file=.env ./node_modules/turbo/bin/turbo run dev --filter=web --filter=worker",
    "dev:https": "node --env-file=.env ./node_modules/turbo/bin/turbo run dev:https --filter=web --filter=worker",
    "dev:mobile": "node --env-file=.env ./node_modules/turbo/bin/turbo run dev",
    "lint": "turbo run lint type-check",
    "test": "jest",
    "test:integration": "jest --runInBand --config jest.integration.smoke.config.js",
    "test:integration:smoke": "pnpm test:integration",
    "test:integration:full": "jest --runInBand --config jest.integration.full.config.js",
    "test:integration:setup": "pnpm turbo run db:push --filter=@repo/database",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "postinstall": "if [ \"$SKIP_TURBO_POSTINSTALL\" = \"1\" ]; then echo \"Skipping turbo prisma:generate postinstall\"; elif [ -f .env ]; then node --env-file=.env ./node_modules/turbo/bin/turbo run prisma:generate; else ./node_modules/turbo/bin/turbo run prisma:generate; fi",
    "dev:split": "node --env-file=.env ./node_modules/turbo/bin/turbo run dev --filter=web --filter=worker --filter=realtime",
    "dev:https:split": "node --env-file=.env ./node_modules/turbo/bin/turbo run dev:https --filter=web --filter=worker --filter=realtime"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/jest": "^30.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "jest": "^30.2.0",
    "jest-environment-node": "30.4.1",
    "jest-mock-extended": "^4.0.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "turbo": "^2.10.5",
    "typescript": "^5"
  }
}
