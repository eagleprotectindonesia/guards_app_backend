{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --watch src/worker.ts",
    "dev:https": "pnpm run dev",
    "build": "esbuild src/worker.ts --bundle --platform=node --target=node22 --outfile=dist/worker.js --external:@prisma/client --external:pg --external:@prisma/adapter-pg --external:ioredis --external:dotenv --external:date-fns --external:bullmq",
    "start": "node dist/worker.js",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@repo/database": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/validations": "workspace:*",
    "bullmq": "^5.66.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "ioredis": "5.9.3",
    "pg": "^8.18.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^20",
    "@typescript-eslint/parser": "^8.52.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.2"
  }
}