{
  "name": "mobile",
  "version": "1.2.0",
  "main": "index.js",
  "scripts": {
    "start": "EXPO_UNSTABLE_HEADLESS=1 expo start",
    "dev": "EXPO_UNSTABLE_HEADLESS=1 expo start",
    "native:clean": "rm -rf android ios",
    "android": "EXPO_UNSTABLE_HEADLESS=1 EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=development expo run:android",
    "android:development": "EXPO_UNSTABLE_HEADLESS=1 EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=development expo run:android",
    "android:preview": "EXPO_UNSTABLE_HEADLESS=1 EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=preview expo run:android",
    "android:production": "EXPO_UNSTABLE_HEADLESS=1 EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=production expo run:android",
    "ios": "EXPO_UNSTABLE_HEADLESS=1 expo run:ios",
    "ios:development": "EXPO_UNSTABLE_HEADLESS=1 EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=development expo run:ios",
    "ios:preview": "EXPO_UNSTABLE_HEADLESS=1 EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=preview expo run:ios",
    "ios:production": "EXPO_UNSTABLE_HEADLESS=1 EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=production expo run:ios",
    "android:prebuild": "EXPO_USE_COMMUNITY_AUTOLINKING=1 expo prebuild --platform android --clean --no-install",
    "android:prebuild:development": "EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=development expo prebuild --platform android --clean --no-install",
    "android:prebuild:preview": "EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=preview expo prebuild --platform android --clean --no-install",
    "android:prebuild:production": "EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=production expo prebuild --platform android --clean --no-install",
    "ios:prebuild": "EXPO_USE_COMMUNITY_AUTOLINKING=1 expo prebuild --platform ios --clean --no-install",
    "ios:prebuild:development": "EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=development expo prebuild --platform ios --clean --no-install",
    "ios:prebuild:preview": "EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=preview expo prebuild --platform ios --clean --no-install",
    "ios:prebuild:production": "EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=production expo prebuild --platform ios --clean --no-install",
    "android:build:development": "EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=development expo prebuild --platform android --clean --no-install && cd android && EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=development ./gradlew assembleDebug",
    "android:build:preview": "EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=preview expo prebuild --platform android --clean --no-install && cd android && EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=preview ./gradlew assembleRelease",
    "android:build:production": "EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=production expo prebuild --platform android --clean --no-install && cd android && EXPO_USE_COMMUNITY_AUTOLINKING=1 APP_VARIANT=production ./gradlew assembleRelease",
    "android:build:eas-local:development": "eas build --local --profile development --platform android",
    "android:build:eas-local:preview": "eas build --local --profile preview --platform android",
    "android:build:eas-local:production": "eas build --local --profile production --platform android",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "build:development": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform android",
    "build:production": "eas build --profile production --platform android",
    "update:preview": "eas update --branch preview",
    "update:preview:android": "eas update --branch preview --platform android",
    "update:production": "eas update --branch production",
    "update:production:android": "eas update --branch production --platform android",
    "update:production:ios": "eas update --branch production --platform ios"
  },
  "dependencies": {
    "@expo/html-elements": "^0.12.5",
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/config": "^1.1.20",
    "@gluestack-ui/core": "^3.0.13",
    "@gluestack-ui/themed": "^1.1.73",
    "@gluestack-ui/utils": "^3.0.15",
    "@legendapp/motion": "^2.5.3",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@repo/shared": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/validations": "workspace:*",
    "@tanstack/react-query": "^5.90.16",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
