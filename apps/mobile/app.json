{
  "expo": {
    "name": "EP Employee",
    "slug": "mobile",
    "scheme": "ep-employee",
    "orientation": "portrait",
    "icon": "./assets/icons/android-launchericon-512-512.png",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": false,
      "bundleIdentifier": "com.eagleprotect.employee",
      "icon": "./assets/icons/180.png",
      "userInterfaceStyle": "light",
      "infoPlist": {
        "UIDeviceFamily": [1],
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "The app needs access to your photo library to let you attach photos and videos to chat messages.",
        "NSCameraUsageDescription": "The app needs access to your camera to take attendance photos and attach photos or videos to chat messages.",
        "NSLocationWhenInUseUsageDescription": "We use your location to record attendance, perform shift check-in, and let you manually share your location in chat.",
        "NSFaceIDUsageDescription": "We use Face ID to let you sign in securely with biometric authentication.",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/android-launchericon-512-512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.eagleprotect.employee",
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "POST_NOTIFICATIONS",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-updates",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "FirebaseCoreInternal",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      "@react-native-firebase/app",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ],
      "expo-secure-store",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-localization",
      "expo-router",
      "expo-video"
    ],
    "updates": {
      "url": "https://u.expo.dev/aa42139c-be53-41d6-8761-ae35510a83ca"
    },
    "owner": "eagleprotect",
    "extra": {
      "eas": {
        "projectId": "aa42139c-be53-41d6-8761-ae35510a83ca"
      }
    }
  }
}
